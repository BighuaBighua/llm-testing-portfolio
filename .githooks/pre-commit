#!/bin/bash
#
# Git Hook: pre-commit
# 功能：在每次 git commit 前自动更新文档
#

echo "🔍 检查项目数据变化..."

# 检查 project_data.json 是否有变化
CHANGED_FILES=$(git diff --cached --name-only)

if echo "$CHANGED_FILES" | grep -q "\.codebuddy/project_data\.json"; then
    echo "📝 检测到 project_data.json 有变化，自动更新文档..."
    
    # 运行文档生成器
    python3 tools/generate_docs.py --auto-update
    
    if [ $? -eq 0 ]; then
        echo "✅ 文档已自动更新"
        
        # 将生成的文档添加到暂存区
        git add README.md scripts/README.md tools/README.md
        
        echo "✅ 已将更新的文档添加到暂存区"
    else
        echo "❌ 文档生成失败，请手动运行: python3 tools/generate_docs.py"
        exit 1
    fi
else
    echo "ℹ️  无需更新文档"
fi

exit 0
