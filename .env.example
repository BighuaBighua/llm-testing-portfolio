# 环境变量配置模板
# 复制此文件为 .env 并填入你的 API Key

# ========================================
# 百度千帆 API（如果使用）
# ========================================
# 获取方式: https://console.bce.baidu.com/qianfan/
QIANFAN_AK=your_access_key_here
QIANFAN_SK=your_secret_key_here

# ========================================
# OpenAI API（如果使用）
# ========================================
# 获取方式: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_key_here

# ========================================
# 通义千问 API（如果使用）
# ========================================
# 获取方式: https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=your_dashscope_key_here

# ========================================
# 其他配置
# ========================================
# 日志级别
LOG_LEVEL=INFO

# 默认模型
DEFAULT_MODEL=ernie-4.5-turbo-128k

# 测试批次目录（可选，默认为 projects/01-ai-customer-service/results/）
# RESULTS_DIR=./results
